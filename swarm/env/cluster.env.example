TIMEZONE=America/Denver
# BASE_DOMAIN is loaded from swarm/env/domain.txt (gitignored) by deploy/reconcile scripts.
# You can still set BASE_DOMAIN here as a fallback.
# BASE_DOMAIN=example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
PAPERLESS_OCR_LANGUAGE=eng
# Set this in swarm/env/cluster.env.local (gitignored) for production.
TECHNITIUM_ADMIN_PASSWORD=change-me
# Set these in swarm/env/cluster.env.local (gitignored) for production.
PAPERLESS_SECRET_KEY=change-me
