TIMEZONE=America/Denver
# BASE_DOMAIN is loaded from swarm/env/domain.txt (gitignored) by deploy/reconcile scripts.
# You can still set BASE_DOMAIN here as a fallback.
# BASE_DOMAIN=example.com
GRAFANA_ADMIN_USER=admin
# Set GRAFANA_ADMIN_PASSWORD in swarm/secrets/cluster-secrets.sops.yaml.
PAPERLESS_OCR_LANGUAGE=eng
BACKUP_NFS_SERVER=192.168.8.20
BACKUP_NFS_EXPORT=/exports/homelab-backups
BACKUP_NFS_VERSION=4.1
RESTIC_BACKUP_INTERVAL_SECONDS=21600
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6
RESTIC_MAX_REPO_BYTES=2199023255552
# Traefik Basic Auth for dash (Homer). Put the real value in swarm/env/cluster.env.local.
# Example: DASH_BASIC_AUTH='kaden:$$apr1$$...'
# DASH_BASIC_AUTH='replace-me'
# Set app secrets in swarm/secrets/cluster-secrets.sops.yaml:
#   TECHNITIUM_ADMIN_PASSWORD
#   TECHNITIUM_API_TOKEN
#   PAPERLESS_SECRET_KEY
